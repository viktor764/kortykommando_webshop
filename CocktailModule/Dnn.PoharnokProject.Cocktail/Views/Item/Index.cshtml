@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<List<PoharnokProject.Dnn.Dnn.PoharnokProject.Cocktail.Models.IngredientCategoryViewModel>>

<style>
    .cocktail-builder {
        max-width: 1100px;
        margin: 40px auto;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: #f4f4f4;
        padding: 50px 20px;
        border-radius: 8px;
    }

    /* Vízszintes elrendezés a kategóriáknak */
    .ingredients-row {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 60px;
    }

    .ingredient-selector {
        display: flex;
        align-items: center;
    }

    .bottle-display {
        width: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* Fix magasságú doboz az üvegnek és árnyéknak a stabil elrendezésért  */
    .image-wrapper {
        position: relative;
        height: 320px;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-end;
    }

    .bottle-img {
        max-height: 280px;
        max-width: 90%;
        z-index: 5;
        object-fit: contain;
        margin-bottom: 20px;
    }

    /* Ovális árnyék az üveg alatt a vizuális terv szerint  */
    .bottle-shadow {
        position: absolute;
        bottom: 0px;
        width: 200px;
        height: 60px;
        background: radial-gradient(ellipse at center, rgba(150,50,150,0.25) 0%, rgba(150,0,150,0) 70%);
        z-index: 1;
    }

    /* Termék adatai az üveg alatt  */
    .prod-info {
        text-align: center;
        margin-top: 15px;
        width: 100%;
    }

    .prod-name {
        font-size: 1.1em;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
        display: block;
    }

    .prod-price {
        font-size: 1em;
        font-weight: bold;
        color: #555;
        display: block;
    }

    /* Navigációs nyilak az üvegek két oldalán  */
    .nav-arrow {
        background: none;
        border: none;
        font-size: 3.5em;
        color: #333;
        cursor: pointer;
        padding: 0 15px;
        transition: transform 0.2s;
        user-select: none;
    }

        .nav-arrow:hover {
            transform: scale(1.15);
        }

    .footer-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 40px;
    }

    .total-text {
        font-size: 1.6em;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .add-to-cart-btn {
        background: #333;
        color: #fff;
        border: none;
        padding: 16px 45px;
        font-size: 1.1em;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

        .add-to-cart-btn:hover {
            background: #000;
        }

        .add-to-cart-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
</style>

<div class="cocktail-builder">
    @if (Model != null && Model.Any())
    {
        <div class="ingredients-row">
            @for (int i = 0; i < Model.Count; i++)
            {
                var category = Model[i];
                <div class="ingredient-selector">
                    @* type="button" megelőzi a postback-et *@
                    <button type="button" class="nav-arrow" onclick="slide(@i, -1)">❮</button>

                    <div class="bottle-display">
                        @for (int p = 0; p < category.Products.Count; p++)
                        {
                            var prod = category.Products[p];
                            <div class="product-card card-row-@i" id="card-@i-@p"
                                 data-price="@prod.SitePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                 data-bvin="@prod.Bvin"
                                 style="@(p == 0 ? "display:flex;" : "display:none;") flex-direction:column; align-items:center; width:100%;">

                                <div class="image-wrapper">
                                    @* Kép elérési útja a Hotcakes belső mappaszerkezete alapján *@
                                    <img src="/Portals/0/Hotcakes/Data/products/@(prod.Bvin)/medium/@(prod.ImageFileMedium)"
                                         alt="@prod.ProductName"
                                         class="bottle-img"
                                         onerror="this.onerror=null; this.src='/Portals/0/no-image.png';" />
                                    <div class="bottle-shadow"></div>
                                </div>

                                <div class="prod-info">
                                    <span class="prod-name">@prod.ProductName</span>
                                    <span class="prod-price">@prod.SitePrice.ToString("N0") Ft</span>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="button" class="nav-arrow" onclick="slide(@i, 1)">❯</button>
                </div>
            }
        </div>

        <div class="footer-section">
            <div class="total-text">
                Csomag értéke: <span id="total-display">0 Ft</span>
            </div>
            @* Dinamikus kosárba helyezés AJAX hívással  *@
            <button type="button" class="add-to-cart-btn" id="btnAddToCart" onclick="addToCart()">Csomag a kosárba</button>
        </div>
    }
    else
    {
        <div style="text-align:center; padding: 20px;">
            A modul beállításaiban válasszon ki legalább egy kategóriát!
        </div>
    }
</div>

<script>
    // Aktuális pozíciók tárolása kategóriánként
    let currentPositions = [@string.Join(",", Model.Select(m => "0"))];
    let maxCounts = [@string.Join(",", Model.Select(m => m.Products.Count))];

    // Lapozás funkció
    function slide(catIndex, direction) {
        const cards = document.querySelectorAll(`.card-row-${catIndex}`);
        cards[currentPositions[catIndex]].style.display = 'none';

        currentPositions[catIndex] = (currentPositions[catIndex] + direction + maxCounts[catIndex]) % maxCounts[catIndex];

        cards[currentPositions[catIndex]].style.display = 'flex';
        calculateTotal();
    }

    // Dinamikus végösszeg számítás JS alapon
    function calculateTotal() {
        let total = 0;
        document.querySelectorAll('.product-card').forEach(card => {
            if (window.getComputedStyle(card).display !== 'none') {
                total += parseFloat(card.getAttribute('data-price')) || 0;
            }
        });
        document.getElementById('total-display').innerText = Math.round(total).toLocaleString('hu-HU') + " Ft";
    }

    // AJAX kosárba helyezés oldalújratöltés nélkül
    function addToCart() {
        const selectedIds = [];
        document.querySelectorAll('.product-card').forEach(card => {
            if (window.getComputedStyle(card).display !== 'none') {
                selectedIds.push(card.getAttribute('data-bvin'));
            }
        });

        if (selectedIds.length === 0) return;

        const btn = document.getElementById('btnAddToCart');
        btn.disabled = true;
        btn.innerText = "Hozzáadás...";

        $.ajax({
            type: "POST",
            url: '@Url.Action("AddToCart", "Item")',
            traditional: true,
            data: { productIds: selectedIds },
            dataType: "json", // Explicit megmondjuk, hogy JSON-t várunk
            success: function (response) {
                if (response.success) {
                    window.location.href = '/cart'; // Ha tiszta a JSON, ide fut be
                } else {
                    alert("Hiba: " + response.message);
                    btn.disabled = false;
                    btn.innerText = "Csomag a kosárba";
                }
            },
            error: function (xhr, textStatus, errorThrown) {
                // ITT A VARÁZSLAT: Ha a státusz 200 (OK), az azt jelenti, hogy a szerver
                // megcsinálta a feladatot, csak a válasz formátuma (parse error) zavarta meg a jQuery-t.
                if (xhr.status === 200) {
                    window.location.href = '/kosar'; // Irány a kosár!
                } else {
                    alert("Sajnos hiba történt a kosárba helyezéskor. Kérjük, próbálja újra!");
                    console.log("Hiba részletei:", textStatus, errorThrown);
                    btn.disabled = false;
                    btn.innerText = "Csomag a kosárba";
                }
            }
        });
    }

    // Inicializálás az oldal betöltésekor
    document.addEventListener("DOMContentLoaded", calculateTotal);
</script>