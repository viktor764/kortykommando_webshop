@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<List<PoharnokProject.Dnn.Dnn.PoharnokProject.Cocktail.Models.IngredientCategoryViewModel>>

@{
    var modId = Dnn.ModuleContext.ModuleId.ToString();
}

<style>
    .cocktail-builder {
        max-width: 1200px;
        width: 100%;
        margin: 40px auto;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background: #f4f4f4;
        padding: 50px 20px;
        border-radius: 8px;
        box-sizing: border-box;
    }

    .ingredients-row {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        flex-wrap: nowrap;
        gap: 15px;
        margin-bottom: 60px;
        overflow-x: auto;
        padding-bottom: 15px;
    }

    .ingredient-selector {
        display: flex;
        align-items: center;
        flex: 1 1 0;
        min-width: 180px;
        max-width: 250px;
    }

    .bottle-display {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .image-wrapper {
        position: relative;
        height: 220px;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: flex-end;
    }

    .bottle-img {
        max-height: 180px;
        max-width: 90%;
        z-index: 5;
        object-fit: contain;
        margin-bottom: 20px;
    }

    .bottle-shadow {
        position: absolute;
        bottom: 0px;
        width: 120px;
        height: 35px;
        background: radial-gradient(ellipse at center, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 70%);
        z-index: 1;
    }

    .prod-info {
        text-align: center;
        margin-top: 15px;
        width: 100%;
    }

    .prod-name {
        font-size: 1.05em;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
        display: block;
        min-height: 40px;
    }

    .prod-price {
        font-size: 1em;
        font-weight: bold;
        color: #555;
        display: block;
    }

    .nav-arrow {
        background: none;
        border: none;
        font-size: 2.5em;
        color: #333;
        cursor: pointer;
        padding: 0 5px;
        transition: transform 0.2s;
        user-select: none;
    }

        .nav-arrow:hover {
            transform: scale(1.15);
        }

    .footer-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 40px;
    }

    .total-text {
        font-size: 1.6em;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .add-to-cart-btn {
        background: #333;
        color: #fff;
        border: none;
        padding: 16px 45px;
        font-size: 1.1em;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s;
    }

        .add-to-cart-btn:hover {
            background: #000;
        }

        .add-to-cart-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
</style>

<div class="cocktail-builder" id="cocktail-module-@modId">
    @if (Model != null && Model.Any())
    {
        <div class="ingredients-row">
            @for (int i = 0; i < Model.Count; i++)
            {
                var category = Model[i];
                <div class="ingredient-selector">
                    <button type="button" class="nav-arrow" onclick="window['slide_@(modId)'](@i, -1)">❮</button>

                    <div class="bottle-display">
                        @for (int p = 0; p < category.Products.Count; p++)
                        {
                            var prod = category.Products[p];
                            <div class="product-card card-row-@i"
                                 data-price="@prod.SitePrice.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                 data-bvin="@prod.Bvin"
                                 style="@(p == 0 ? "display:flex;" : "display:none;") flex-direction:column; align-items:center; width:100%;">

                                <div class="image-wrapper">
                                    <img src="/Portals/0/Hotcakes/Data/products/@(prod.Bvin)/medium/@(prod.ImageFileMedium)"
                                         alt="@prod.ProductName"
                                         class="bottle-img"
                                         onerror="this.onerror=null; this.src='/Portals/0/no-image.png';" />
                                    <div class="bottle-shadow"></div>
                                </div>

                                <div class="prod-info">
                                    <span class="prod-name">@prod.ProductName</span>
                                    <span class="prod-price">@prod.SitePrice.ToString("N0") Ft</span>
                                </div>
                            </div>
                        }
                    </div>

                    <button type="button" class="nav-arrow" onclick="window['slide_@(modId)'](@i, 1)">❯</button>
                </div>
            }
        </div>

        <div class="footer-section">
            <div class="total-text">
                Csomag értéke: <span class="total-display">0 Ft</span>
            </div>

            <form id="cart-form-@modId" action="@Url.Action("AddToCart", "Item")" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productIdsString" id="cart-product-ids-@modId" value="" />

                <button type="button" class="add-to-cart-btn btnAddToCart" onclick="window['submitChillForm_@(modId)']()">Csomag a kosárba</button>
            </form>
        </div>
    }
    else
    {
        <div style="text-align:center; padding: 20px;">
            A modul beállításaiban válasszon ki legalább egy kategóriát!
        </div>
    }
</div>

<script>
    (function () {
        const modId = '@modId';
        const container = document.getElementById('cocktail-module-' + modId);

        if (!container) return;

        let currentPositions = [@string.Join(",", Model.Select(m => "0"))];
        let maxCounts = [@string.Join(",", Model.Select(m => m.Products.Count))];

        window['slide_' + modId] = function (catIndex, direction) {
            const cards = container.querySelectorAll('.card-row-' + catIndex);
            if (cards.length > 0) {
                cards[currentPositions[catIndex]].style.display = 'none';
                currentPositions[catIndex] = (currentPositions[catIndex] + direction + maxCounts[catIndex]) % maxCounts[catIndex];
                cards[currentPositions[catIndex]].style.display = 'flex';
                calculateTotal();
            }
        };

        function calculateTotal() {
            let total = 0;
            container.querySelectorAll('.product-card').forEach(card => {
                if (window.getComputedStyle(card).display !== 'none') {
                    total += parseFloat(card.getAttribute('data-price')) || 0;
                }
            });
            const displayEl = container.querySelector('.total-display');
            if (displayEl) {
                displayEl.innerText = Math.round(total).toLocaleString('hu-HU') + " Ft";
            }
        }

        // Laza form küldés
        window['submitChillForm_' + modId] = function () {
            const selectedIds = [];
            container.querySelectorAll('.product-card').forEach(card => {
                if (window.getComputedStyle(card).display !== 'none') {
                    selectedIds.push(card.getAttribute('data-bvin'));
                }
            });

            if (selectedIds.length === 0) {
                alert("Kérjük, válasszon ki termékeket!");
                return;
            }

            // Betesszük a rejtett mezőbe az ID-kat
            document.getElementById('cart-product-ids-' + modId).value = selectedIds.join(',');

            // Gomb letiltása dupla kattintás ellen
            const btn = container.querySelector('.btnAddToCart');
            btn.disabled = true;
            btn.innerText = "Feldolgozás...";

            // Sima űrlap beküldése
            document.getElementById('cart-form-' + modId).submit();
        };
        calculateTotal();
    })();
</script>